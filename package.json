{
  "name": "pipedreamz",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "pages": "npm run build && rm -rf assets && cp -R dist/assets assets && cp dist/dev.html index.html && touch .nojekyll",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "sim": "RUN_SIM=1 vitest run --config vitest.sim.config.ts"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
